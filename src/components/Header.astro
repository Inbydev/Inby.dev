---

<header>
	<ul class="header__box">
		<li class="header__items"><a class="header__link" href="#about" aria-label="About"><ion-icon class="icon__header" name="people-outline"></ion-icon></a></li>
		<li class="header__items"><a class="header__link" href="#home" aria-label="Home"><img loading="lazy" class="header__logo" src="Images/logo_header.webp" alt="InbyLogo"></a></li>
		<li class="header__items"><a class="header__link" href="#proyects" aria-label="Proyects"><ion-icon class="icon__header" name="code-working-outline"></ion-icon></a></li>
	</ul>
</header>
<nav class="header__mobile__container">
	<ul class="header__mobile">
		<li class="header__mobile__items"><a class="header__mobile__link" href="#about" aria-label="About"><ion-icon class="icon__header__mobile" name="people-outline"></ion-icon></a></li>
		<li class="header__mobile__items"><a class="header__mobile__link not" href="#home" aria-label="Home"><img loading="lazy" class="header__mobile__logo" src="Images/logo_header.webp" alt="InbyLogo"></a></li>
		<li class="header__mobile__items"><a class="header__mobile__link" href="#proyects" aria-label="Proyects"><ion-icon class="icon__header__mobile" name="code-working-outline"></ion-icon></a></li>
		<li class="header__mobile__toggle"></li>
	</ul>
</nav>

<style>
	.link-card {
		list-style: none;
		display: flex;
		padding: 1px;
		background-color: #23262d;
		background-image: none;
		background-size: 400%;
		border-radius: 7px;
		background-position: 100%;
		transition: background-position 0.6s cubic-bezier(0.22, 1, 0.36, 1);
		box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.1);
	}
	.link-card > a {
		width: 100%;
		text-decoration: none;
		line-height: 1.4;
		padding: calc(1.5rem - 1px);
		border-radius: 8px;
		color: white;
		background-color: #23262d;
		opacity: 0.8;
	}
	h2 {
		margin: 0;
		font-size: 1.25rem;
		transition: color 0.6s cubic-bezier(0.22, 1, 0.36, 1);
	}
	p {
		margin-top: 0.5rem;
		margin-bottom: 0;
	}
	.link-card:is(:hover, :focus-within) {
		background-position: 0;
		background-image: var(--accent-gradient);
	}
	.link-card:is(:hover, :focus-within) h2 {
		color: rgb(var(--accent-light));
	}
</style>
