---
const AGRADECIMIENTOS = [
    {
        title: "Aliceki",
        description: "Por estar aquí desde el principio y apoyarme en esto en todo momento <3."
    },
    {
        title: "Fredoist",
        description: "por ayudarme con un problema que tenía mi header, además de ayudarme con un problema de la barra de scroll, gracias!"
    },
    {
        title: "Abizahir Romero",
        description: "Ayudo a entender mejor mi código, entender porque la semántica es importante y a ver algo que yo no podía ver."
    },
    {
        title: "Mamá",
        description: "Por apoyarme en mi pasión."
    },
    {
        title: "Cosmo",
        description: "Por intentar ayudarme a arreglar el error de la fuente cortada, entender mejor el error y ayudarme con un error de scroll horizontal."
    },
    {
        title: "Darío Valenzuela",
        description: "Por intentar ayudarme con la fuente y probar mi página InNotesBy dándome feedback."
    },
    {
        title: "Midudev",
        description: "Por incentivarme y enseñarme cosas que no pude haber logrado sin tu ayuda!"
    }
]
---

{
    AGRADECIMIENTOS.map(({ title, description }, index) => (
        <div class="card">
            <span></span>
            <span></span>
            <span></span>
            <span></span>
            <div class="card_content">
                <h2>0{index + 1}</h2>
                <h3>{title}</h3>
                <p>{description}</p>
            </div>
        </div>
    ))
}

<style is:inline>
    .cards_container {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
        flex-wrap: wrap;
    }
    .cards_container .card {
        position: relative;
        opacity: 0.4;
        transition: 0.2s;
        width: 300px;
        height: 400px;
        background: var(--background);
        display: flex;
        justify-content: center;
        align-items: center;
        margin: 30px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.2);
        overflow: hidden;
        
    }

    .cards_container .card:hover {
        opacity: 1;
    }

    .cards_container .card::before {
        content: '';
        position: absolute;
        top: 2px;
        left: 2px;
        bottom: 2px;
        width: 50%;
        background: rgba(255,255,255,0.1);
        pointer-events: none;
    }

    .cards_container .card .card_content {
        padding: 30px;
        text-align: center;
    }

    .cards_container .card .card_content h2 {
        position: absolute;
        font-size: 4em;
        font-family: "Concert One";
        z-index: 1;
        opacity: 0;
        transition: var(--a-s);
        color: var(--other);
        right: 30px;
        top: 30%;
    }

    .cards_container .card:hover .card_content h2 {
        opacity: 1;
        transform: translateY(-110%);
    }

    .cards_container .card .card_content h3 {
        position: relative;
        font-size: 1.5em;
        font-weight: 800;
        color: #FFF;
        z-index: 2;
        opacity: 0.5;
        letter-spacing: 1px;
        transition: 0.5s;
    }

    .cards_container .card:hover .card_content h3,
    .cards_container .card:hover .card_content p{
        opacity: 1;
    }

    .cards_container .card .card_content p {
        position: relative;
        text-align: center;
        font-size: 1em;
        font-weight: 300;
        color: #FFF;
        z-index: 2;
        opacity: 0.5;
        transition: 0.5s;
    }

    .cards_container .card .card_content a {
        display: inline-block;
        margin-top: 15px;
        padding: 8px 15px;
        background: #FFF;
        color: #0c002b;
        text-decoration: none;
        text-transform: uppercase;
        font-weight: 600;
    }

    .cards_container .card span {
        transition: 0.5s;
        opacity: 0;
        padding-bottom: 0;
    }


    .cards_container .card:hover span {
        opacity: 1;
    }



    .cards_container .card span:nth-child(1) {
        position: absolute;
        top: 0;
        right: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(to right, transparent, #1799ff);
        animation: animate1 2s linear infinite;
    }

    @keyframes animate1
    {
        0% {transform: translateX(-100%);}
        100% {transform: translateX(100%);}
    }




    .cards_container .card span:nth-child(2) {
        position: absolute;
        top: 0;
        right: 0;
        width: 3px;
        height: 100%;
        background: linear-gradient(to bottom, transparent, #1799ff);
        animation: animate2 2s linear infinite;
        animation-delay: 1s;
    }

    @keyframes animate2
    {
        0% {transform: translateY(-100%);}
        100% {transform: translateY(100%);}
    }




    .cards_container .card span:nth-child(3) {
        position: absolute;
        bottom: 0;
        left: 0;
        width: 100%;
        height: 3px;
        background: linear-gradient(to left, transparent, #1799ff);
        animation: animate3 2s linear infinite;
    }

    @keyframes animate3
    {
        0% {transform: translateX(100%);}
        100% {transform: translateX(-100%);}
    }




    .cards_container .card span:nth-child(4) {
        position: absolute;
        top: 0;
        left: 0;
        width: 3px;
        height: 100%;
        background: linear-gradient(to top, transparent, #1799ff);
        animation: animate4 2s linear infinite;
        animation-delay: 1s;
    }

    @keyframes animate4
    {
        0% {transform: translateY(100%);}
        100% {transform: translateY(-100%);}
    }
</style>