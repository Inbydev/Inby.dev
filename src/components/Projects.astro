---
import IcoAstro from  './icons/icoAstro.astro';
import IcoPHP from  './icons/icoPHP.astro';
import IcoCSS from  './icons/icoCSS.astro';
import IcoJS from  './icons/icoJS.astro';
import IcoGitHub from  './icons/icoGitHub.astro';
import IcoWeb from  './icons/icoWeb.astro';
import LinkButton from  './LinkButton.astro';

const TAGS = {
    ASTRO: {
        name: "Astro",
        class: "ASTRO",
        icon: IcoAstro,
    },
    PHP: {
        name: "PHP",
        class: "PHP",
        icon: IcoPHP,
    },
    CSS: {
        name: "CSS",
        class: "CSS",
        icon: IcoCSS,
    },
    JS: {
        name: "JavaScript",
        class: "JS",
        icon: IcoJS,
    }
}

const PROJECTS = [
    {
        title: "InNotesBy",
        description: "Para crear Notas para acceso público con PHP",
        link: "#",
        github: "https://github.com/Inbydev/InNotesBy",
        image: "/src/Images/InNotesBy_screenshot.webp",
        tags: [TAGS.PHP, TAGS.CSS, TAGS.JS]
    }
]
---

{
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
        <article class="project__article">
            <h3>{title}</h3>
            <p>{description}</p>
            <ul>
                {tags.map(tag => (
                    <li>
                        <span class={tag.class}>
                            <tag.icon class="svg"/>
                            {tag.name}
                        </span>
                    </li>
                ))}
            </ul>
            <img src={image} alt={`Captura de pantalla del proyecto ${title}`}>
            <footer class="footer">
                <LinkButton href={github}>
                    <IcoGitHub class="svg__link" />
                    Ver código fuente
                </LinkButton>
                <LinkButton href={link}>
                    <IcoWeb class="svg__link" />
                    Ir al sitio web
                </LinkButton>
            </footer>
        </article>
    ))
}

<style>
    .project__article {
        padding: 15px;
        display: flex;
        max-height: 46rem;
        max-width: 48rem;
        gap: 1.25rem;
        flex-direction: column;
        justify-content: center;
	}
    
    .project__article > * {
        margin: 0;
        padding: 0;
    }

    .project__article footer{
        background: transparent;
        display: flex;
        justify-content: start;
        align-items: center;
        gap: 1rem;
	}

	.project__article h3 {
        display: flex;
        align-items: center;
		transition: var(--h-s);
		color: var(--secondary-text);
        text-align: left;
	}

    .project__article ul {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .project__article li {
        list-style: none;
        color: var(--tertiary-text);
    }

    .svg {
        height: 1rem;
        aspect-ratio: 1;
    }

    .svg__link {
        height: 2.25rem;
        aspect-ratio: 1;
        transition: var(--f-h-s);
        font-family: none;
    }

    .project__article li span {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.25rem 0.5rem;
        border-radius: 1rem;
        font-size: 1rem;
        color: var(--primary-text);
    }

    .project__article li span.ASTRO {
        background: #2c2052;
    }

    .project__article li span.PHP {
        background: #777bb4;
    }

    .project__article li span.CSS {
        background: #12649e;
    }

    .project__article li span.JS {
        background: #333330;
    }


    .project__article p {
        display: flex;
        align-items: center;
        max-width: 48ch;
        font-size: 1.4rem;
        line-height: 2rem;
        text-wrap: balance;
        text-align: left;
    }

    .project__article img {
        width: 100%;
        object-fit: cover;
        aspect-ratio: 16/9;
        border-radius: 8px;
        border: 2px solid var(--primary-text);
        -webkit-box-shadow: 0px 17px 60px 0px rgba(106,35,138,0.5);
        -moz-box-shadow: 0px 17px 60px 0px rgba(106,35,138,0.5);
        box-shadow: 0px 17px 60px 0px rgba(106,35,138,0.5);
    }
</style>