---
import ASTROicon from  './icons/ASTROicon.astro';
import RUSTicon from  './icons/RUSTicon.astro';
import CSSicon from  './icons/CSSicon.astro';
import JSicon from  './icons/JSicon.astro';
import GitHub from  './icons/GITHUBicon.astro';
import LinkButton from  './LinkButton.astro';

const TAGS = {
    ASTRO: {
        name: "Astro",
        class: "ASTRO",
        icon: ASTROicon,
    },
    RUST: {
        name: "Rust",
        class: "RUST",
        icon: RUSTicon,
    },
    CSS: {
        name: "CSS",
        class: "CSS",
        icon: CSSicon,
    },
    JS: {
        name: "JavaScript",
        class: "JS",
        icon: JSicon,
    }
}

const PROJECTS = [
    {
        title: "InNotesBy",
        description: "A webpage to create Notes for public or private access with Astro",
        link: "#",
        github: "https://github.com/Inbydev/InNotesBy",
        image: "https://www.twine.net/blog/wordpress/wp-content/uploads/2022/10/Screenshot-2022-10-21-at-16.41.03.png",
        tags: [TAGS.ASTRO, TAGS.CSS, TAGS.JS]
    },
    {
        title: "InSuccessBy",
        description: "Application for Track your Tasks like Challenges in a Game with Rust",
        link: "#",
        github: "https://github.com/Inbydev/InSuccessBy",
        image: "https://www.twine.net/blog/wordpress/wp-content/uploads/2022/10/Screenshot-2022-10-21-at-16.41.03.png",
        tags: [TAGS.RUST, TAGS.CSS, TAGS.JS]
    }
]
---

{
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
        <article class="project__article">
            <h3>{title}</h3>
            <p>{description}</p>
            <ul>
                {tags.map(tag => (
                    <li>
                        <span class={tag.class}>
                            <tag.icon class="svg"/>
                            {tag.name}
                        </span>
                    </li>
                ))}
            </ul>
            <img src={image} alt={`Captura de pantalla del proyecto ${image}`}>
            <footer class="footer">
                <LinkButton href={github}>
                    <GitHub class="svg__link" />
                    Ver código fuente
                </LinkButton>
                <LinkButton href={link}>
                    <svg class="svg__link"
                    viewBox="0 0 24 24"
                    stroke-width="1.5"
                    stroke="var(--primary-text)"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    >
                    <>
                        <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                        <path d="M19.5 7a9 9 0 0 0 -7.5 -4a8.991 8.991 0 0 0 -7.484 4" />
                        <path d="M11.5 3a16.989 16.989 0 0 0 -1.826 4" />
                        <path d="M12.5 3a16.989 16.989 0 0 1 1.828 4" />
                        <path d="M19.5 17a9 9 0 0 1 -7.5 4a8.991 8.991 0 0 1 -7.484 -4" />
                        <path d="M11.5 21a16.989 16.989 0 0 1 -1.826 -4" />
                        <path d="M12.5 21a16.989 16.989 0 0 0 1.828 -4" />
                        <path d="M2 10l1 4l1.5 -4l1.5 4l1 -4" />
                        <path d="M17 10l1 4l1.5 -4l1.5 4l1 -4" />
                        <path d="M9.5 10l1 4l1.5 -4l1.5 4l1 -4" />
                    </>
                    </svg>
                    Ir al sitio web
                </LinkButton>
            </footer>
        </article>
    ))
}

<style>
    .project__article {
        padding: 15px;
        display: flex;
        height: 48rem;
        max-width: 48rem;
        overflow: hidden;
        gap: 1.25rem;
        flex-direction: column;
        justify-content: center;
	}
    
    .project__article > * {
        margin: 0;
        padding: 0;
    }

    .project__article footer{
        background: transparent;
        display: flex;
        justify-content: start;
        align-items: center;
        gap: 1rem;
	}

	.project__article h3 {
        display: flex;
        align-items: center;
		transition: var(--h-s);
		color: var(--secondary-text);
        text-align: left;
	}

    .project__article ul {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .project__article li {
        list-style: none;
        color: var(--tertiary-text);
    }

    .svg {
        height: 1rem;
        aspect-ratio: 1;
    }

    .svg__link {
        height: 2rem;
        aspect-ratio: 1;
        transition: var(--f-h-s);
    }

    .project__article li span {
        display: flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.25rem 0.5rem;
        border-radius: 1rem;
        font-size: 1rem;
        color: var(--primary-text);
    }

    .project__article li span.ASTRO {
        background: #2c2052;
    }

    .project__article li span.RUST {
        background: #000000;
    }

    .project__article li span.CSS {
        background: #12649e;
    }

    .project__article li span.JS {
        background: #333330;
    }


    .project__article p {
        display: flex;
        align-items: center;
        max-width: 48ch;
        font-size: 1.4rem;
        line-height: 2rem;
        text-wrap: balance;
        text-align: left;
    }

    .project__article img {
        width: 100%;
        object-fit: cover;
        aspect-ratio: 16/9;
        border-radius: 8px;
    }
</style>