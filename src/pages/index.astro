---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Background from "../components/Background.astro";


---

<Layout title="Inbydev">
	<Background>
	<Header>
	<main>
		
	</main>
</Layout>

<style>
	@font-face {
		font-family: "Shizuru";
		src:
			url("../src/FONTS/Shizuru-Regular.woff2") format("woff2"),
			url("../src/FONTS/Shizuru-Regular.woff") format("woff"),
			url("../src/FONTS/Shizuru-Regular.ttf") format("truetype");
		font-style: normal;
		font-weight: normal;
		font-display: swap;
	}

	@font-face {
		font-family: "Single Day";
		src:
			url("../src/FONTS/SingleDay-Regular.woff2") format("woff2"),
			url("../src/FONTS/SingleDay-Regular.woff") format("woff"),
			url("../src/FONTS/SingleDay-Regular.ttf") format("truetype");
		font-style: normal;
		font-weight: normal;
		font-display: swap;
	}

	h1::before {
		position: absolute;
		content: "インビー";
		font-family: "Shizuru";
		z-index: -1;
		font-size: 0.4em;
		opacity: 0.2;
		inset: 46svh 4em 0 0;
		color: var(--primary-text);
	}

	h1::after {
		position: absolute;
		content: "인비";
		font-family: "Single Day";
		z-index: -1;
		font-size: 0.4em;
		opacity: 0.2;
		inset: 47svh 0 0 5.4em;
		color: var(--primary-text);
	}

	.h2__title {
		font-size: clamp(100% - 20px, 9.5vw, 70px);
	}

	.h2__title span {
		display: inline-table;
	}

	.h2__title span:nth-child(1) {
		background: linear-gradient(to right, #c08bfd, #fca6fd);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.h2__title span:nth-child(2) {
		background: linear-gradient(to right, #87cafa, #878cfa);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.more__info {
		cursor: pointer;
		color: var(--tertiary-text);
	}

	.proyects__section {
		display: flex;
		flex-direction: column;
		gap: 2em;
		min-height: 50dvh;
	}

	.proyects__container {
		display: flex;
		flex-wrap: wrap;
		align-content: center;
		justify-content: center;
		gap: 4em;
	}

	.proyects__h4 {
		letter-spacing: 0;
		transition: var(--h-s);
		color: var(--secondary-text);
		background: var(--hover);
		border-radius: 12px;
		padding: 5px 15px;
		height: 56px;
	}

	.proyects__link:hover .proyects__h4 {
		letter-spacing: 0.1em;
		color: var(--hover);
		background: var(--secondary-text);
	}

	.about__container {
		display: flex;
		justify-content: center;
		align-items: flex-start;
		align-content: flex-start;
		gap: 3em;
		margin: 0 4em 0 4em;
		min-height: 54dvh;
	}

	.about {
		width: 90%;
		max-width: 600px;
		gap: 2em;
		display: grid;
	}

	.p__start {
		text-align: start;
	}

	.p__start span:nth-child(1) {
		color: var(--secondary-text);
	}

	.p__start span:nth-child(2) {
		color: var(--secondary-text);
	}

	.content {
		display: flex;
		justify-content: center;
	}

	.tagcloud {
		font-size: var(--fs-tag);
		line-height: var(--lh-tag);
	}

	.tagcloud--item {
		padding: 2px 4px;
		cursor: pointer;
		color: var(--secondary-text);
	}

	.tagcloud--item:hover {
		opacity: 1 !important;
		z-index: 100 !important;
	}

	@media (max-width: 1045px) {
		.about__container {
			flex-wrap: wrap;
		}

		.about__container {
			margin: 0 auto 4em auto;
		}
	}

	@media (max-width: 488px) {
		.proyects__container {
			flex-direction: column;
		}

		.proyects__link:hover .proyects__h4 {
			letter-spacing: 0;
		}
	}
</style>
